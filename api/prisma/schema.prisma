// prisma/schema.prisma — SupportFlow
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMINISTRADOR
  AGENTE
  SOLICITANTE
}

enum TicketStatus {
  ABIERTO
  EN_PROGRESO
  PENDIENTE
  RESUELTO
  CERRADO
}

enum Priority {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum CommentType {
  PUBLIC
  INTERNAL
}

model User {
  id                  String               @id @default(uuid())
  name                String
  email               String               @unique
  password            String
  role                UserRole             @default(SOLICITANTE)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ticketsCreated      Ticket[]             @relation("CreatedBy")
  ticketsAssigned     Ticket[]             @relation("AssignedTo")
  comments            TicketComment[]
  history             TicketHistory[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model Ticket {
  id           String          @id @default(uuid())
  code         String          @unique
  title        String
  description  String
  status       TicketStatus    @default(ABIERTO)
  priority     Priority        @default(MEDIA)
  categoryId   String
  category     Category        @relation(fields: [categoryId], references: [id])
  createdById  String
  createdBy    User            @relation("CreatedBy", fields: [createdById], references: [id])
  assignedToId String?
  assignedTo   User?           @relation("AssignedTo", fields: [assignedToId], references: [id])
  comments     TicketComment[]
  history      TicketHistory[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?
  closedAt   DateTime?

  @@map("tickets")
}

model TicketComment {
  id        String      @id @default(uuid())
  ticketId  String
  ticket    Ticket      @relation(fields: [ticketId], references: [id])
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  message   String
  type      CommentType @default(PUBLIC)
  createdAt DateTime    @default(now())

  @@map("ticket_comments")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  tickets     Ticket[]
  createdAt   DateTime @default(now())

  @@map("categories")
}

model TicketHistory {
  id        String       @id @default(uuid())
  ticketId  String
  ticket    Ticket       @relation(fields: [ticketId], references: [id])
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  oldStatus TicketStatus
  newStatus TicketStatus
  createdAt DateTime     @default(now())

  @@map("ticket_history")
}
